   "source": [
    "# Sum of squares of first n natural numbers"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "409a5e38-4590-4130-9b3d-0971988d4a02",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "385\n"
     ]
    }
   ],
   "source": [
    "def sum_of_square(n):\n",
    "    total = 0\n",
    "    for i in range(1 , n+1):\n",
    "        total = total + (i ** 2)\n",
    "    return total\n",
    "\n",
    "print(sum_of_square(10))"
   ]
