   ],
   "source": [
    "def findsum(n):\n",
    "    a = 0\n",
    "    i = 1\n",
    "\n",
    "    while i <= n:\n",
    "        a = a + i\n",
    "        i = i + 1\n",
    "    return a\n",
    "\n",
    "n = 19\n",
    "print(findsum(n))"
   ]
