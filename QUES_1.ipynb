   "source": [
    "# checking a number whether it is a even or odd number\n",
    "\n",
    "def evenodd(n):\n",
    "    if n % 2 == 0:\n",
    "        return \"EVEN\"\n",
    "    else:\n",
    "        return \"ODD\"\n",
    "\n",
    "print(evenodd(12))\n",
    "print(evenodd(33))"
   ]
